# ─────────────────────────────────────────────────────────────────────────────
# LinkSheet — Environment Variable Template
#
# USAGE:
#   1. Copy this file to .env (never commit .env to version control)
#   2. Fill in real values
#   3. For local dev, export these variables in your shell or use a .env loader
# ─────────────────────────────────────────────────────────────────────────────

# ── Django Core ────────────────────────────────────────────────────────────────
# Generate your own with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-this-with-a-random-50-char-string

# Use "False" in production, "True" in development
DJANGO_DEBUG=True

# Comma-separated list of allowed hostnames (no spaces)
# Example: myapp.com,www.myapp.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ───────────────────────────────────────────────────────────────────
# If set, uses PostgreSQL. If omitted, falls back to local SQLite.
# Example: postgres://user:password@host:5432/dbname
# DATABASE_URL=

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Must match EXACTLY what is registered in Google Cloud Console → Credentials
GOOGLE_REDIRECT_URI=http://localhost:8000/google/callback/
# Provide these in production to avoid needing the linksheet.json file
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Token Encryption (Fernet) ─────────────────────────────────────────────────
# Generate a new key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠️ Changing this key will make all existing encrypted tokens unreadable.
FIELD_ENCRYPTION_KEY=replace-with-your-generated-fernet-key

# ── Celery / Redis ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=django-db
